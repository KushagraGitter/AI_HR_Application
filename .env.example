# ==============================================================================
# AI HR Agent — Environment Variables
# Copy this file to .env.local for local development.
# For Vercel, add each variable in Project Settings → Environment Variables.
# ==============================================================================

# --- LLM (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model ID — see https://openrouter.ai/models for options
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Database (Postgres in production, SQLite via file:./dev.db for local) ---
# Vercel Postgres: use POSTGRES_PRISMA_URL as DATABASE_URL (pooled connection)
# and POSTGRES_URL_NON_POOLING as DIRECT_URL (direct connection).
# Vercel auto-injects these when you connect a Postgres database to the project.
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# --- Email (Resend) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender. Without a verified domain, use the default onboarding address.
RESEND_FROM_EMAIL="Siftly <onboarding@resend.dev>"
# While on Resend free tier without verified domain, emails only deliver to the
# account owner. Set this to the owner email to auto-reroute all outgoing email.
# Remove once a domain is verified at resend.com/domains.
RESEND_TEST_REDIRECT_TO=your-resend-account-email@example.com

# --- Demo controls ---
# Artificial delay (ms) between agent steps so judges can see the handoffs.
# Set to 0 for production.
AGENT_DEMO_DELAY_MS=1500
